# Auto detect text files and normalize line endings to LF
* text=auto

# Python files
*.py text eol=lf
*.ipynb text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows files
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.h5 binary
*.pkl binary
*.pickle binary
*.joblib binary
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary

# Git files
.gitignore text eol=lf
.gitattributes text eol=lf
